rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Fields: content (string), updatedAt (timestamp), authorUid (string)
    //
    // Collection: curriculums
    // Fields: title (string), content (string), attachments (list), createdAt (timestamp), authorUid (string)
    //
    // Collection: lectures
    // Fields: title (string), content (string), date (string), attachments (list), createdAt (timestamp), authorUid (string)
    //
    // Collection: articles
    // Fields: title (string), content (string), type (string), createdAt (timestamp), authorUid (string)
    //
    // Collection: sharedLinks
    // Fields: url (string), title (string), description (string), thumbnail (string), type (string), createdAt (timestamp), authorUid (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jabang78@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /curriculums/{curriculumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lectures/{lectureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sharedLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
